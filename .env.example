# Configuration locale de CH-Portal-Budgy — copier vers .env (jamais commité).

# Port d'écoute du serveur de dev Vite
PORT=3203

# URL du CH-Api-GateWay vers lequel le serveur proxifie les appels /api
GATEWAY_URL=http://localhost:8180

# URL du portail d'authentification (redirection en cas de session absente/expirée)
VITE_AUTH_PORTAL_URL=http://localhost:3200
